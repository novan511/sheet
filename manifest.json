{
  "manifest_version": 3,
  "name": "Pencari Data Sheet",
  "version": "1.0",
  "description": "Floating button untuk mencari dan memfilter data dari Google Sheet.",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://search.tiktok-row.net/*",
        "https://docs.google.com/*",
        "*://*.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}